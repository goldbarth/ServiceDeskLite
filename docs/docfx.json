{
    "build": {
        "content": [
            { "files": [ "**/*.md", "**/toc.yml" ], "src": "." }
        ],
        "resource": [
            { "files": [ "**/*.png", "**/*.jpg", "**/*.svg", "**/*.gif" ], "src": "." }
        ],
        "template": [
            "default"
        ],
        "postProcessors": [ "ExtractSearchIndex" ],
        "styles": [],
        "scripts": [
            "styles/mermaid.js"
        ],
        "markdownEngineProperties": {
            "markdigExtensions": [
                "PipeTables",
                "AutoIdentifiers",
                "AutoLinks"
            ]
        },
        "dest": "_site",
        "globalMetadata": {
            "_appTitle": "ServiceDeskLite Documentation",
            "_enableSearch": true
        }
    }
}
